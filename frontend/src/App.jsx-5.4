import { useState } from "react";

const API =
  import.meta.env.VITE_API_URL ||
  `${window.location.protocol}//${window.location.hostname}:8000`;

const REGIONS = [
  "us-east-1",
  "us-east-2",
  "us-west-2",
  "eu-west-1",
  "ap-south-1",
];

export default function App() {
  const [mode, setMode] =
    useState("single");

  const [dark, setDark] =
    useState(false);

  const [loading, setLoading] =
    useState(false);

  const [logs, setLogs] =
    useState("");

  const [jobStatus, setJobStatus] =
    useState("");

  const [primary, setPrimary] =
    useState(null);

  const [standby, setStandby] =
    useState(null);

  const [regions, setRegions] =
    useState([
      "us-east-1",
      "us-east-2",
    ]);

  const [form, setForm] =
    useState({
      clusterName: "",
      workers: 1,
      instanceType:
        "t2.medium",
      region: "us-east-1",
      standbyRegion:
        "us-east-2",
      k8sVersion:
        "1.29",
      deployApp: false,
    });

  const bg = dark
    ? "bg-slate-950 text-white"
    : "bg-slate-100 text-slate-900";

  const card = dark
    ? "bg-slate-900 border-slate-800"
    : "bg-white border-slate-200";

  const input = dark
    ? "bg-slate-950 border-slate-700 text-white"
    : "bg-white border-slate-300";

  const handleChange = (
    e
  ) => {
    const {
      name,
      value,
      type,
      checked,
    } = e.target;

    setForm({
      ...form,
      [name]:
        type ===
        "checkbox"
          ? checked
          : name ===
            "workers"
          ? Number(
              value
            )
          : value,
    });
  };

  const toggleRegion = (
    region
  ) => {
    if (
      regions.includes(
        region
      )
    ) {
      setRegions(
        regions.filter(
          (r) =>
            r !==
            region
        )
      );
    } else {
      setRegions([
        ...regions,
        region,
      ]);
    }
  };

  // ===================================
  // LIVE LOG STREAM
  // ===================================
  const startLogs = (
    jobId
  ) => {
    const evt =
      new EventSource(
        `${API}/jobs/${jobId}/stream`
      );

    evt.onmessage = (
      e
    ) => {
      setLogs(
        (
          prev
        ) =>
          prev +
          e.data +
          "\n"
      );

      if (
        e.data.includes(
          "Cluster Ready"
        )
      ) {
        setJobStatus(
          "completed"
        );
        setLoading(
          false
        );
        evt.close();
      }

      if (
        e.data.includes(
          "ERROR"
        )
      ) {
        setJobStatus(
          "failed"
        );
        setLoading(
          false
        );
        evt.close();
      }
    };

    evt.onerror = () => {
      evt.close();
      setLoading(
        false
      );
    };
  };

  // ===================================
  // SINGLE CLUSTER
  // ===================================
  const createSingle =
    async () => {
      setLoading(true);
      setLogs("");
      setJobStatus(
        "starting"
      );

      try {
        const res =
          await fetch(
            `${API}/create-cluster`,
            {
              method:
                "POST",
              headers:
                {
                  "Content-Type":
                    "application/json",
                },
              body: JSON.stringify(
                {
                  clusterName:
                    form.clusterName,
                  workers:
                    Number(
                      form.workers
                    ),
                  instanceType:
                    form.instanceType,
                  region:
                    form.region,
                  k8sVersion:
                    form.k8sVersion,
                  deployApp:
                    false,
                }
              ),
            }
          );

        const data =
          await res.json();

        if (
          data.jobId
        ) {
          setPrimary({
            region:
              form.region,
            status:
              "Provisioning",
          });

          setStandby({
            region:
              form
                .standbyRegion,
            status:
              "Standby",
          });

          startLogs(
            data.jobId
          );
        }
      } catch (
        err
      ) {
        setLogs(
          "❌ " +
            err.message
        );
        setLoading(
          false
        );
      }
    };

  // ===================================
  // MULTI REGION
  // ===================================
  const createMulti =
    async () => {
      setLoading(true);
      setLogs("");
      setJobStatus(
        "starting"
      );

      try {
        const res =
          await fetch(
            `${API}/create-multi-region`,
            {
              method:
                "POST",
              headers:
                {
                  "Content-Type":
                    "application/json",
                },
              body: JSON.stringify(
                {
                  clusterName:
                    form.clusterName,
                  workers:
                    Number(
                      form.workers
                    ),
                  instanceType:
                    form.instanceType,
                  regions:
                    regions,
                  k8sVersion:
                    form.k8sVersion,
                  deployApp:
                    false,
                }
              ),
            }
          );

        const data =
          await res.json();

        setLogs(
          JSON.stringify(
            data,
            null,
            2
          )
        );

        setLoading(
          false
        );
      } catch (
        err
      ) {
        setLogs(
          "❌ " +
            err.message
        );
        setLoading(
          false
        );
      }
    };

  return (
    <div
      className={`min-h-screen ${bg}`}
    >
      <div className="flex">

        {/* SIDEBAR */}
        <aside
          className={`w-72 min-h-screen border-r p-6 ${card}`}
        >
          <h1 className="text-2xl font-bold">
            ☸ K8s SaaS
          </h1>

          <p className="text-sm opacity-70 mt-2">
            Enterprise Dashboard
          </p>

          <div className="mt-8">
            <p className="text-xs uppercase opacity-60">
              Provisioning
            </p>

            <div className="mt-4 font-semibold text-sm">
              ☁ Cluster
            </div>

            <button
              onClick={() =>
                setMode(
                  "single"
                )
              }
              className="w-full text-left px-4 py-2 rounded-xl mt-2 hover:bg-slate-200 hover:text-black"
            >
              single-cluster
            </button>

            <button
              onClick={() =>
                setMode(
                  "multi"
                )
              }
              className="w-full text-left px-4 py-2 rounded-xl mt-2 hover:bg-slate-200 hover:text-black"
            >
              multi region cluster
            </button>
          </div>

          <div className="mt-10">
            <button
              onClick={() =>
                setDark(
                  !dark
                )
              }
              className="w-full rounded-xl py-3 bg-slate-700 text-white"
            >
              {dark
                ? "☀ Light"
                : "🌙 Dark"}
            </button>
          </div>
        </aside>

        {/* MAIN */}
        <main className="flex-1 p-6 space-y-6">

          {/* HERO */}
          <div
            className={`rounded-2xl border p-6 ${card}`}
          >
            <h2 className="text-3xl font-bold">
              🚀 Premium Cluster Dashboard
            </h2>

            <p className="opacity-70 mt-2">
              Real-time Kubernetes provisioning platform
            </p>
          </div>

          {/* FORM */}
          <div
            className={`rounded-2xl border p-6 space-y-4 ${card}`}
          >
            <h3 className="text-xl font-semibold">
              {mode ===
              "single"
                ? "Single Cluster Provisioning"
                : "Multi Region Provisioning"}
            </h3>

            <input
              name="clusterName"
              placeholder="Cluster Name"
              onChange={
                handleChange
              }
              className={`w-full border rounded-xl px-4 py-3 ${input}`}
            />

            <input
              name="workers"
              type="number"
              value={
                form.workers
              }
              onChange={
                handleChange
              }
              className={`w-full border rounded-xl px-4 py-3 ${input}`}
            />

            <select
              name="instanceType"
              onChange={
                handleChange
              }
              className={`w-full border rounded-xl px-4 py-3 ${input}`}
            >
              <option>
                t2.medium
              </option>
              <option>
                t3.medium
              </option>
            </select>

            <select
              name="region"
              onChange={
                handleChange
              }
              className={`w-full border rounded-xl px-4 py-3 ${input}`}
            >
              {REGIONS.map(
                (
                  r
                ) => (
                  <option
                    key={
                      r
                    }
                  >
                    {r}
                  </option>
                )
              )}
            </select>

            {mode ===
              "single" && (
              <select
                name="standbyRegion"
                onChange={
                  handleChange
                }
                className={`w-full border rounded-xl px-4 py-3 ${input}`}
              >
                {REGIONS.map(
                  (
                    r
                  ) => (
                    <option
                      key={
                        r
                      }
                    >
                      {r}
                    </option>
                  )
                )}
              </select>
            )}

            {mode ===
              "multi" && (
              <div className="grid grid-cols-2 gap-3">
                {REGIONS.map(
                  (
                    region
                  ) => (
                    <label
                      key={
                        region
                      }
                      className="border rounded-xl p-4 flex gap-2"
                    >
                      <input
                        type="checkbox"
                        checked={regions.includes(
                          region
                        )}
                        onChange={() =>
                          toggleRegion(
                            region
                          )
                        }
                      />
                      {region}
                    </label>
                  )
                )}
              </div>
            )}

            <button
              onClick={
                mode ===
                "single"
                  ? createSingle
                  : createMulti
              }
              disabled={
                loading
              }
              className="w-full bg-blue-600 text-white py-3 rounded-xl hover:bg-blue-700 transition"
            >
              {loading
                ? "⏳ Processing..."
                : mode ===
                  "single"
                ? "🚀 Create Cluster"
                : "🌍 Create Multi Region"}
            </button>
          </div>

          {/* STATUS */}
          {(primary ||
            standby) && (
            <div className="grid md:grid-cols-2 gap-4">
              {primary && (
                <Card
                  title="Primary Cluster"
                  value={
                    primary.region
                  }
                  status={
                    loading
                      ? "Provisioning"
                      : "Ready"
                  }
                  card={
                    card
                  }
                />
              )}

              {standby && (
                <Card
                  title="Standby Cluster"
                  value={
                    standby.region
                  }
                  status="Standby"
                  card={
                    card
                  }
                />
              )}
            </div>
          )}

          {/* PROGRESS */}
          <div
            className={`rounded-2xl border p-6 ${card}`}
          >
            <h3 className="font-semibold text-lg">
              Deployment Status
            </h3>

            <div className="mt-4">
              <div className="h-3 bg-slate-300 rounded-full overflow-hidden">
                <div
                  className={`h-full ${
                    loading
                      ? "w-2/3 animate-pulse bg-blue-600"
                      : jobStatus ===
                        "completed"
                      ? "w-full bg-green-600"
                      : "w-0"
                  }`}
                />
              </div>

              <p className="mt-2 text-sm opacity-70">
                {loading
                  ? "Provisioning in progress..."
                  : jobStatus ===
                    "completed"
                  ? "Cluster Ready"
                  : "Idle"}
              </p>
            </div>
          </div>

          {/* LIVE LOGS */}
          <div
            className={`rounded-2xl border p-6 ${card}`}
          >
            <h3 className="text-xl font-semibold mb-4">
              📜 Live Logs
            </h3>

            <pre className="bg-black text-green-400 rounded-xl p-4 h-96 overflow-auto text-sm whitespace-pre-wrap">
              {logs ||
                "Waiting for deployment..."}
            </pre>
          </div>
        </main>
      </div>
    </div>
  );
}

function Card({
  title,
  value,
  status,
  card,
}) {
  return (
    <div
      className={`rounded-2xl border p-6 ${card}`}
    >
      <h3 className="font-semibold text-lg">
        {title}
      </h3>

      <p className="mt-3">
        Region: {value}
      </p>

      <p className="mt-1">
        Status: {status}
      </p>
    </div>
  );
}
